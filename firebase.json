    "frameworksBackend": {
      "region": "us-central1",
      "secrets": ["FB_PRIVATE_KEY", "RESEND_API_KEY", "CONNECTEAM_API_KEY", "QBO_CLIENT_ID", "QBO_CLIENT_SECRET", "GOOGLE_MAPS_API_KEY"],
      "environmentVariables": {
        "FB_PROJECT_ID": "stlyardgames",
        "FB_CLIENT_EMAIL": "firebase-adminsdk-fbsvc@stlyardgames.iam.gserviceaccount.com",
        "FB_STORAGE_BUCKET": "stlyardgames.firebasestorage.app",
        "NEXT_PUBLIC_APP_URL": "https://stlyardgames.com",
        "QBO_REDIRECT_BASE": "https://stlyardgames.com",
        "QBO_SANDBOX": "false",
        "CONNECTEAM_SCHEDULER_ID": "4385224",
        "NEXT_PUBLIC_CONNECTEAM_SCHEDULER_ID": "4385224"
