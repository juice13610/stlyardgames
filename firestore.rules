rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Public can only read their own contract by ID (no auth needed for signing)
    match /contracts/{contractId} {
      allow read: if true;
      // Signing (write) is done via server-side API route — no direct client writes
      allow write: if false;
    }

    // All admin data requires Firebase Auth
    match /reservations/{id} {
      allow read, write: if request.auth != null
        && request.auth.token.email in [
          'joeytomsfbr@gmail.com',
          'joey.toms@gmail.com',
          'rcfacedesigns@gmail.com'
        ];
    }

    match /settings/{id} {
      allow read, write: if request.auth != null
        && request.auth.token.email in [
          'joeytomsfbr@gmail.com',
          'joey.toms@gmail.com',
          'rcfacedesigns@gmail.com'
        ];
    }

    match /customers/{id} {
      allow read, write: if request.auth != null
        && request.auth.token.email in [
          'joeytomsfbr@gmail.com',
          'joey.toms@gmail.com',
          'rcfacedesigns@gmail.com'
        ];
    }
  }
}
